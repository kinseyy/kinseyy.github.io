<tr>
<th>字段</th>
<th>名称</th>
<th>必填</th>
</tr>
</thead>
<tbody>
<tr>
<td>name</td>
<td>名称</td>
<td>是</td>
</tr>
<tr>
<td>url</td>
<td>地址</td>
<td>是</td>
</tr>
<tr>
<td>image</td>
<td>图片</td>
<td>是</td>
</tr>
<tr>
<td>color</td>
<td>颜色</td>
<td>是</td>
</tr>
<tr>
<td>desc</td>
<td>描述</td>
<td>否</td>
</tr>
</tbody>
</table>
